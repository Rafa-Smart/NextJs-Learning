CARA 1: Cache dengan waktu (Revalidation)
import { cacheLife } from "next/cache";
async function getProducts() {
  "use cache";
  cacheLife("seconds"); // misalnya 10 detik
  return db.product.findMany();
}
10 detik pertama → pakai cache
setelah itu → ambil DB lagi


Cara 2 recomended jadi manual untu hapus cachena

/jadi ketiak post dia akan hapus cache di get mana aja yang ngambil data dari hasil post data barusan

import { cacheLife } from "next/cache";

export async function GET() {
  const products = await getProducts(); // di pnagigl ya di sin si getproductnya
  return Response.json(products);
}

async function getProducts() {
  "use cache";
  cacheLife("hours");

  return db.product.findMany();
}

// nah pas di post nnya akan gini
import { revalidatePath } from "next/cache";

export async function POST(req: Request) {
  const body = await req.json();

  await db.product.create({
    data: body
  });

  //  HAPUS CACHE
  revalidatePath("/api/products");

  return Response.json({ message: "produk ditambah" });
}